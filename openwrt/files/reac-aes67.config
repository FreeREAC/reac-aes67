# /etc/config/reac-aes67 — REAC -> AES67 bridge configuration.
#
# Single source of truth. The procd init script spawns one daemon instance per
# enabled 'stream' section. Runtime state is published over ubus, NOT here.
#
# Rate is NOT auto-detected here — you MUST set it to match the REAC clock master
# (mixer). Every rate carries 40 channels x 12 samples/packet; only the packet rate
# differs (pps = rate/12: 48000 -> 4000 pps, 96000 -> 8000 pps). 96 kHz does not
# halve channels.

config reac-aes67 'global'
	option enabled '1'

config stream 'a'
	option enabled '1'
	option name 'REAC-A'
	option iface 'lan1'
	option rate '48000'
	option mcast_addr '239.69.0.1'
	option mcast_port '5004'
	option payload_type '97'
	option ssrc '11223344'
	option ttl '1'
	option sap '1'              # SAP/AES67 auto-discovery announce (1=on)
	# option plc_xfade '0'      # 0 = default crossfade width
	# option plc_fade_pkts '0'  # 0 = default burst fade length

#config stream 'b'
#	option enabled '0'
#	option name 'REAC-B'
#	option iface 'lan2'
#	option rate '48000'
#	option mcast_addr '239.69.0.2'
#	option mcast_port '5006'
#	option payload_type '98'
#	option ssrc '11223355'
#	option ttl '1'

#config stream 'c'
#	option enabled '0'
