# --- Dante-interop stream (profile=dante) ---
# Re-emits REAC as AES67 that a DANTE network accepts: 48 kHz, 1 ms packets,
# split into <=8-ch multicast flows from 'aes67_base' (here 239.69.10.0..4 for
# 40 ch), RFC 7273 SDP announced via SAP to 239.255.255.255:9875.
# REQUIRES the router PTPv2-slaved to the Dante grandmaster — install ptp4l with
# /etc/ptp4l-dante.conf (slaveOnly, domain 0). Set 'gmid' to the grandmaster
# clockId (pmc -> GET CLOCK_DESCRIPTION) so Dante confirms the shared clock.
# Also: lock the V-mixer and the PTP grandmaster to ONE house clock, or the
# audio will drift/glitch (Dante does not resample inbound AES67).
#config stream 'dante'
#	option enabled '0'
#	option profile 'dante'
#	option name 'REAC-A'
#	option iface 'lan1'
#	option aes67_base '239.69.10.0'
#	option rtp_port '5004'
#	option ch_per_flow '8'
#	option payload_type '96'
#	option ssrc '11223344'
#	option ttl '32'
#	option ptp_domain '0'
#	option gmid '00-11-22-FF-FE-33-44-55'
#	option egress_iface 'br-lan'
#	option sap '1'
